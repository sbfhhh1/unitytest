  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MainMenuPrototypeController
  sections:
  - key: launch
    headline: "\u51C6\u5907\u8FDB\u5165\u8FDC\u5F81\u8230\u6865"
    summary: "\u628A\u73A9\u5BB6\u6CE8\u610F\u529B\u96C6\u4E2D\u5230\u552F\u4E00\u7684\u9AD8\u4EF7\u503C\u4E3B\u5165\u53E3\u4E0A\u3002\u8FD9\u4E2A\u7248\u672C\u5F3A\u8C03\u6807\u9898\u3001\u8BF4\u660E\u3001\u4E3B\u6309\u94AE\u4E0E\u9884\u89C8\u533A\u4E4B\u95F4\u7684\u8282\u594F\u5173\u7CFB\uFF0C\u8BA9\u9996\u5C4F\u66F4\u50CF\u4E00\u6B3E\u771F\u6B63\u53EF\u4EA4\u4E92\u7684\u5546\u4E1A\u6E38\u620F\u6807\u9898\u9875\u3002"
    accentLabel: "\u65D7\u8230\u822A\u7EBF\u5BF9\u9F50\u5B8C\u6210"
    accentColor: {r: 0.42, g: 0.92, b: 1, a: 1}
  - key: resume
    headline: "\u7EE7\u7EED\u4E0A\u4E00\u6B21\u822A\u7A0B"
    summary: "\u7A81\u51FA\u201C\u56DE\u6D41\u201D\u4F53\u9A8C\uFF0C\u5FEB\u901F\u5448\u73B0\u6700\u8FD1\u8FDB\u5EA6\u3001\u53EF\u7EE7\u7EED\u72B6\u6001\u4E0E\u7CFB\u7EDF\u786E\u8BA4\u4FE1\u606F\uFF0C\u8BA9\u56DE\u5230\u6E38\u620F\u8FD9\u4E00\u6B65\u8DB3\u591F\u8F7B\u3001\u8DB3\u591F\u5FEB\u3002"
    accentLabel: "\u81EA\u52A8\u5B58\u6863\u6D41\u7A33\u5B9A"
    accentColor: {r: 0.62, g: 0.88, b: 1, a: 1}
  - key: hangar
    headline: "\u67E5\u770B\u8230\u8239\u673A\u5E93"
    summary: "\u673A\u5E93\u9875\u8D1F\u8D23\u4F20\u8FBE\u4E2D\u5C42\u7CFB\u7EDF\u6DF1\u5EA6\uFF0C\u6697\u793A\u89D2\u8272\u517B\u6210\u3001\u8F7D\u5177\u6539\u9020\u4E0E\u6536\u85CF\u5185\u5BB9\uFF0C\u4E3A\u6574\u4E2A\u4E3B\u754C\u9762\u8865\u4E0A\u4E16\u754C\u89C2\u4E0E\u7CFB\u7EDF\u5E7F\u5EA6\u3002"
    accentLabel: "\u8230\u4F53\u8BCA\u65AD\u53EF\u7528"
    accentColor: {r: 0.49, g: 1, b: 0.84, a: 1}
  - key: settings
    headline: "\u6821\u51C6\u753B\u9762\u4E0E\u63A7\u5236"
    summary: "\u8BBE\u7F6E\u9875\u662F\u53EF\u7528\u6027\u4E0E\u79E9\u5E8F\u611F\u7684\u91CD\u8981\u90E8\u5206\u3002\u5B83\u5728\u8FD9\u4E2A\u539F\u578B\u91CC\u627F\u62C5\u5207\u9875\u3001\u72B6\u6001\u4FDD\u6301\u3001\u8272\u5F69\u5207\u6362\u4E0E\u4FE1\u606F\u5E03\u5C40\u590D\u7528\u7684\u5C55\u793A\u4EFB\u52A1\u3002"
    accentLabel: "\u6821\u51C6\u5957\u4EF6\u5728\u7EBF"
    accentColor: {r: 0.95, g: 0.86, b: 0.48, a: 1}
  - key: archive
    headline: "\u68C0\u89C6\u6863\u6848\u4E0E\u56DE\u62A5"
    summary: "\u6863\u6848\u9875\u627F\u62C5\u66F4\u5B89\u9759\u7684\u4FE1\u606F\u8868\u8FBE\u89D2\u8272\uFF0C\u8BA9\u754C\u9762\u4ECE\u201C\u542F\u52A8\u611F\u201D\u5EF6\u5C55\u5230\u201C\u5185\u5BB9\u611F\u201D\u3002"
    accentLabel: "\u6863\u6848\u8282\u70B9\u5DF2\u540C\u6B65"
    accentColor: {r: 0.92, g: 0.7, b: 1, a: 1}
  buttons:
