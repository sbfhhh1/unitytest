  m_Name: 
  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Block.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 114350483966675185}
  m_Children: []
  m_UIPosition: {x: 0, y: 0}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 114350483966675207}
  - {fileID: 114350483966675208}
  - {fileID: 114350483966675209}
  m_OutputSlots: []
  m_Disabled: 0
  m_ActivationSlot: {fileID: 114350483966675206}
  m_BlockName: SetGridPosition
  m_HLSLCode: "void SetGridPosition(inout VFXAttributes attributes, uint particleIdx,
    float spacing, float gridSize)\n{\n    uint col = particleIdx % (uint)gridSize;\n   
    uint row = particleIdx / (uint)gridSize;\n    float halfGrid = (gridSize - 1.0)
    * spacing * 0.5;\n    attributes.position.x = (float)col * spacing - halfGrid;\n   
    attributes.position.y = 0.0;\n    attributes.position.z = (float)row * spacing
    - halfGrid;\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunction:
    selection: SetGridPosition
    selectedIndex: 0
